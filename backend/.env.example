# Copy to backend/.env and set your Splunk Web password (never commit .env).
SPLUNK_USER=cjalessi
SPLUNK_PASSWORD=your-splunk-password

# Or store the password in a file (mode 600) and omit SPLUNK_PASSWORD:
# SPLUNK_PASSWORD_FILE=/home/you/.splunk_pass

SPLUNK_VERIFY_SSL=false
SPLUNK_AUTH_INDEX=trustops
SPLUNK_DECISION_INDEX=trustops_decisions
SPLUNK_AGENT_RUN_INDEX=trustops_agent_runs

# SAIA uses Splunk REST /predict (v1, same as Search UI). MCP saia_* uses broken v2 on many stacks.
# SAIA_USE_MCP=true
# SAIA_SOURCE_APP_ID=search
